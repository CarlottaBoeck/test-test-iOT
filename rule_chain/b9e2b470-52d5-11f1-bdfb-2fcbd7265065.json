                "type": "org.thingsboard.rule.engine.filter.TbJsFilterNode"
            },
            {
                "additionalInfo": {
                    "description": "Auslastungsberechnung + zeitbasierte Preisprognose (Erweiterung 1)",
                    "layoutX": 1295,
                    "layoutY": 150
                },
                "configuration": {
                    "scriptLang": "JS",
                    "jsScript": "// ===== PARKING & BOOKING LOGIC mit zeitbasierter Preisprognose =====\nvar totalSpaces = 100;\nvar occupiedSpaces = msg.occupied_spaces;\nif (occupiedSpaces == null) occupiedSpaces = 0;\noccupiedSpaces = Number(occupiedSpaces);\nif (isNaN(occupiedSpaces)) occupiedSpaces = 0;\nif (occupiedSpaces < 0) occupiedSpaces = 0;\nif (occupiedSpaces > totalSpaces) occupiedSpaces = totalSpaces;\n\nvar freeSpaces = totalSpaces - occupiedSpaces;\nvar occupancyRate = (occupiedSpaces / totalSpaces) * 100;\n\nvar basePrice = msg.base_price_per_hour;\nif (basePrice == null) basePrice = 2.0;\nbasePrice = Number(basePrice);\nif (isNaN(basePrice)) basePrice = 2.0;\n\nvar duration = msg.requested_duration_hours;\nif (duration == null) duration = 1;\nduration = Number(duration);\nif (isNaN(duration)) duration = 1;\n\n// === Auslastungsbasierter Preis ===\nvar priceFactor = 1.0;\nvar demandLevel = \"LOW\";\nif (occupancyRate < 50) { priceFactor = 1.0; demandLevel = \"LOW\"; }\nelse if (occupancyRate < 80) { priceFactor = 1.2; demandLevel = \"MEDIUM\"; }\nelse if (occupancyRate < 95) { priceFactor = 1.5; demandLevel = \"HIGH\"; }\nelse { priceFactor = 2.0; demandLevel = \"CRITICAL\"; }\n\n// === Erweiterung 1: Zeitbasierter Prognose-Multiplikator ===\nvar now = new Date();\nvar dayOfWeek = now.getDay(); // 0=So, 1=Mo, 2=Di ... 6=Sa\nvar hour = now.getHours();\nvar forecastMultiplier = 1.0;\nvar forecastLabel = \"Normal\";\n\nif (dayOfWeek >= 1 && dayOfWeek <= 5) { // Wochentag\n    if (hour >= 7 && hour < 9) { forecastMultiplier = 1.3; forecastLabel = \"Morgenspitze\"; }\n    else if (hour >= 9 && hour < 12) { forecastMultiplier = 1.2; forecastLabel = \"Vormittag hoch\"; }\n    else if (hour >= 12 && hour < 14) { forecastMultiplier = 1.25; forecastLabel = \"Mittagspitze\"; }\n    else if (hour >= 17 && hour < 19) { forecastMultiplier = 1.4; forecastLabel = \"Abendspitze\"; }\n    else if (hour >= 22 || hour < 6) { forecastMultiplier = 0.7; forecastLabel = \"Niedrigtarif Nacht\"; }\n} else { // Wochenende\n    if (hour >= 10 && hour < 16) { forecastMultiplier = 1.1; forecastLabel = \"Wochenende tagsüber\"; }\n    else { forecastMultiplier = 0.8; forecastLabel = \"Wochenende ruhig\"; }\n}\n\nvar currentPricePerHour = Math.round(basePrice * priceFactor * forecastMultiplier * 100) / 100;\nvar bookingPrice = Math.round(currentPricePerHour * duration * 100) / 100;\n\n// === Prognose nächste Stunde ===\nvar nextHour = (hour + 1) % 24;\nvar forecastNextMultiplier = 1.0;\nif (dayOfWeek >= 1 && dayOfWeek <= 5) {\n    if (nextHour >= 7 && nextHour < 9) forecastNextMultiplier = 1.3;\n    else if (nextHour >= 17 && nextHour < 19) forecastNextMultiplier = 1.4;\n    else if (nextHour >= 22 || nextHour < 6) forecastNextMultiplier = 0.7;\n}\nvar forecastNextPrice = Math.round(basePrice * forecastNextMultiplier * 100) / 100;\n\n// === Buchungslogik ===\nvar bookingStatus = msg.booking_status;\nif (bookingStatus == null) bookingStatus = \"no_booking_request\";\nvar reservedSpaceId = \"none\";\nif (bookingStatus == \"requested\") {\n    if (freeSpaces > 0) {\n        bookingStatus = \"confirmed\";\n        reservedSpaceId = \"P-\" + (occupiedSpaces + 1);\n        occupiedSpaces = occupiedSpaces + 1;\n        freeSpaces = totalSpaces - occupiedSpaces;\n        occupancyRate = (occupiedSpaces / totalSpaces) * 100;\n    } else {\n        bookingStatus = \"rejected\";\n        reservedSpaceId = \"none\";\n    }\n}\n\n// === Display-Logik ===\nvar bookingAvailable = freeSpaces > 0;\nvar displayStatus = \"AVAILABLE\";\nvar displayMessage = freeSpaces + \" Plätze frei – \" + currentPricePerHour + \"€/h\";\nif (freeSpaces <= 0) { bookingAvailable = false; displayStatus = \"FULL\"; displayMessage = \"Parkhaus voll\"; }\nelse if (freeSpaces <= 10) { displayStatus = \"LIMITED\"; displayMessage = \"Nur noch \" + freeSpaces + \" Plätze frei\"; }\n\n// === Tagesreport Felder ===\nvar dailyRevenue = msg.daily_revenue;\nif (dailyRevenue == null) dailyRevenue = 0;\nvar dailyBookings = msg.daily_bookings;\nif (dailyBookings == null) dailyBookings = 0;\nif (bookingStatus == \"confirmed\") {\n    dailyRevenue = Math.round((dailyRevenue + bookingPrice) * 100) / 100;\n    dailyBookings = dailyBookings + 1;\n}\n\n// === Ergebnis ===\nmsg.total_spaces = totalSpaces;\nmsg.occupied_spaces = occupiedSpaces;\nmsg.free_spaces = freeSpaces;\nmsg.occupancy_rate = Math.round(occupancyRate * 100) / 100;\nmsg.base_price_per_hour = basePrice;\nmsg.current_price_per_hour = currentPricePerHour;\nmsg.booking_price = bookingPrice;\nmsg.demand_level = demandLevel;\nmsg.booking_status = bookingStatus;\nmsg.reserved_space_id = reservedSpaceId;\nmsg.booking_available = bookingAvailable;\nmsg.display_status = displayStatus;\nmsg.display_message = displayMessage;\nmsg.forecast_label = forecastLabel;\nmsg.forecast_multiplier = forecastMultiplier;\nmsg.forecast_next_hour_price = forecastNextPrice;\nmsg.daily_revenue = dailyRevenue;\nmsg.daily_bookings = dailyBookings;\nmsg.debug_script_executed = true;\nmsg.debug_free_spaces_before_booking = totalSpaces - Number(msg.occupied_spaces);\n\nreturn {msg: msg, metadata: metadata, msgType: msgType};",
                    "tbelScript": "return {msg: msg, metadata: metadata, msgType: msgType};"
                },
                "configurationVersion": 0,
                "createdTime": 0,
                "debugSettings": null,
                "externalId": null,
