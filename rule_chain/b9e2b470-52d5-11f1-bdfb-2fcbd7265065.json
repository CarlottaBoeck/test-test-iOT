            {
                "additionalInfo": {
                    "description": "Wetter-Check: P4 freigeben + Rabatt wenn Wetter gut",
                    "layoutX": 1350,
                    "layoutY": 400
                },
                "configuration": {
                    "scriptLang": "JS",
                    "jsScript": "// === E-Parkplatz P4: Wetter-basierte Freigabe & Preislogik ===\n// Wetterdaten werden als Telemetrie erwartet (z.B. von openweathermap via HTTP Integration)\n// Keys: weather_temp_c, weather_condition (\"clear\", \"rain\", \"snow\", \"fog\"), weather_wind_kmh\n\nvar weatherCondition = msg.weather_condition;\nif (weatherCondition == null) weatherCondition = \"clear\"; // Default: freigegeben\n\nvar weatherTemp = msg.weather_temp_c;\nif (weatherTemp == null) weatherTemp = 15;\nweatherTemp = Number(weatherTemp);\n\nvar windSpeed = msg.weather_wind_kmh;\nif (windSpeed == null) windSpeed = 0;\nwindSpeed = Number(windSpeed);\n\n// Gut: kein Regen, kein Schnee, kein starker Wind, nicht zu kalt\nvar goodWeather = (\n    weatherCondition != \"rain\" &&\n    weatherCondition != \"snow\" &&\n    weatherCondition != \"thunderstorm\" &&\n    weatherCondition != \"fog\" &&\n    weatherTemp > 5 &&\n    windSpeed < 50\n);\n\n// P4 Status setzen\nmsg.p4_ev_enabled = goodWeather;\nmsg.p4_weather_reason = goodWeather ? \"Wetter OK – E-Parkplatz aktiv\" : \"Schlechtes Wetter – E-Parkplatz gesperrt (\" + weatherCondition + \")\";\n\n// Rabatt bei gutem Wetter\nvar baseEVPrice = 3.0; // E-Parkplatz Grundpreis (inkl. Laden)\nif (goodWeather) {\n    msg.p4_price_per_hour = Math.round(baseEVPrice * 0.8 * 100) / 100; // 20% Rabatt\n    msg.p4_discount_label = \"20% Sonnenschein-Rabatt aktiv!\";\n} else {\n    msg.p4_price_per_hour = baseEVPrice;\n    msg.p4_discount_label = \"Kein Rabatt\";\n}\n\nmsg.p4_weather_temp = weatherTemp;\nmsg.p4_weather_condition = weatherCondition;\n\nreturn {msg: msg, metadata: metadata, msgType: msgType};",
                    "tbelScript": "return {msg: msg, metadata: metadata, msgType: msgType};"
                },
